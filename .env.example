# .env.example: Template for environment variables
# Copy this file to .env and update with your values

# Project directory (absolute path - REQUIRED for Rancher Desktop)
# Update this to match your actual project location
# Example: /home/username/projects/PGVectorRAGIndexer
PROJECT_DIR=/path/to/your/PGVectorRAGIndexer

# Database Host (Docker will map 5432 to localhost)
DB_HOST=localhost
DB_PORT=5432

# Database Credentials - MUST match the values in docker-compose.yml
POSTGRES_DB=rag_vector_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password

# Database connection pool
# DB_POOL_SIZE is the steady-state max connection count. DB_MAX_OVERFLOW adds
# burst capacity above that. DB_POOL_TIMEOUT controls how long a request waits
# for a slot before failing.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# License key verification (server operators only — desktop clients do NOT need this)
# RS256 public key override. If set, takes priority over LICENSE_SIGNING_SECRET.
# Leave empty to use the public key embedded in license.py (default for all clients).
LICENSE_PUBLIC_KEY=

# Legacy HMAC signing secret (HS256). Only used for backward compatibility with
# pre-v2.6.9 license keys. Leave empty unless you issued HS256 keys previously.
LICENSE_SIGNING_SECRET=

# API rate limiting
# Default is 60 requests per minute per API key or client IP. Set to 0 only
# when an upstream proxy or gateway enforces equivalent limits.
# Desktop App bulk indexing/probe calls bypass this generic limiter.
API_RATE_LIMIT_PER_MINUTE=60

# Document indexing size limit
# Default 0 means no application-level cap for local/server indexing. Set a
# positive value only when an operator intentionally wants to reject larger
# files, for example MAX_FILE_SIZE_MB=512.
MAX_FILE_SIZE_MB=0

# SCIM 2.0 Provisioning (Enterprise)
# Enables automated user provisioning from identity providers (Okta, Azure AD, etc.)
# See docs/SCIM_SETUP.md for IdP configuration guides.
SCIM_ENABLED=false
SCIM_BEARER_TOKEN=
SCIM_DEFAULT_ROLE=user
